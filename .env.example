# Cointer backend configuration. Copy to .env and adjust.
# Every value is optional. The values shown are the defaults.

# --- Server ---
PORT=3000
DATABASE_PATH=./data/cointer.db
# Comma-separated list of allowed CORS origins, or * for any.
CORS_ORIGINS=*
# Set to true when running behind a reverse proxy so rate limits see the real
# client IP. Requests pass through Cloudflare then nginx, so the nearest hop
# is nginx — TRUST_PROXY_HEADER stays x-forwarded-for.
TRUST_PROXY=false
TRUST_PROXY_HEADER=x-forwarded-for

# --- Chains ---
# Comma-separated chain ids to enable (adapters exist for: bitcoin, ethereum,
# litecoin, base, solana, bitcoin-cash, monero).
ENABLED_CHAINS=bitcoin,ethereum

# --- Ingestion ---
WATCHERS_ENABLED=true
BITCOIN_ESPLORA_URL=https://mempool.space/api
BITCOIN_POLL_INTERVAL_MS=30000
# Pause between per-address Esplora requests within one poll.
BITCOIN_ADDRESS_GAP_MS=250
ETHEREUM_RPC_URL=https://ethereum-rpc.publicnode.com
ETHEREUM_POLL_INTERVAL_MS=15000
ETHEREUM_MAX_CATCHUP_BLOCKS=50
# ERC-20 tokens to watch, TICKER:0xaddress:decimals comma-separated.
# Default: USDC, USDT, DAI mainnet contracts.
#ETHEREUM_ERC20_TOKENS=USDC:0xa0b86991c6218b36c1d19d4a2e9eb0ce3606eb48:6
# Ignore txs older than this many days (must be < ACTIVITY_RETENTION_DAYS).
INGEST_MAX_AGE_DAYS=7

# Litecoin. Same Esplora-shaped API as Bitcoin, hosted by litecoinspace.org.
LITECOIN_ESPLORA_URL=https://litecoinspace.org/api
LITECOIN_POLL_INTERVAL_MS=30000
LITECOIN_ADDRESS_GAP_MS=250

# Base (Coinbase L2, EVM). Same JSON-RPC shape as Ethereum, faster blocks.
BASE_RPC_URL=https://base-rpc.publicnode.com
BASE_POLL_INTERVAL_MS=5000
BASE_MAX_CATCHUP_BLOCKS=300
# Default: native USDC, DAI, EURC on Base. TICKER:0xaddress:decimals comma-separated.
#BASE_ERC20_TOKENS=USDC:0x833589fcd6edb6e08f4c7c32d4f71b54bda02913:6

# Solana. Polls getSignaturesForAddress/getTransaction, no block cursor.
SOLANA_RPC_URL=https://solana-rpc.publicnode.com
SOLANA_POLL_INTERVAL_MS=10000
SOLANA_ADDRESS_GAP_MS=250
SOLANA_SIGNATURES_PER_POLL=100
# Default: USDC, USDT SPL mints. TICKER:mintAddress:decimals comma-separated.
#SOLANA_SPL_TOKENS=USDC:EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v:6

# Bitcoin Cash, via Blockchair (no Esplora-shaped API exists for BCH). Free
# tier is tightly rate-limited (1,440 req/day, 30/min) — keep the poll
# interval conservative, and consider an API key for more than a few addresses.
BITCOIN_CASH_EXPLORER_URL=https://api.blockchair.com/bitcoin-cash
#BITCOIN_CASH_EXPLORER_API_KEY=
BITCOIN_CASH_POLL_INTERVAL_MS=120000
BITCOIN_CASH_ADDRESS_GAP_MS=2000

# Monero. Requires the monero-wallet-rpc binary installed on this host (not
# an npm/bun dependency — see the Monero project releases) and at least one
# remote node to connect to. Deposit detection needs a private VIEW key per
# address (see API.md POST /addresses) — never a spend key.
MONERO_WALLET_RPC_PATH=monero-wallet-rpc
# Comma-separated host:port list, no default (public nodes churn — pick
# current ones from https://monero.fail or https://xmr.ditatompel.com/remote-nodes).
#MONERO_REMOTE_NODES=
MONERO_POLL_INTERVAL_MS=60000

# --- Prices (CoinGecko) ---
PRICES_ENABLED=true
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
#COINGECKO_API_KEY=
PRICE_REFRESH_INTERVAL_MS=60000
# Cached prices older than this are treated as missing.
PRICE_STALENESS_MS=900000
PRICE_CURRENCY=usd
# Extra ticker to CoinGecko id mappings, TICKER:coingecko-id comma-separated.
# BTC, ETH, USDC, USDT, DAI, LTC, BCH, SOL, XMR, EURC are mapped by default.
#PRICE_COINGECKO_IDS=

# --- Email (channel type "email") ---
# Option A: Cloudflare Email Service over HTTPS (takes precedence when set).
#CLOUDFLARE_ACCOUNT_ID=
#CLOUDFLARE_EMAIL_API_TOKEN=
#EMAIL_FROM=Cointer <notify@example.com>
# Option B: SMTP fallback (used if Cloudflare Email isn't configured).
#SMTP_HOST=
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASS=
#SMTP_FROM=Cointer <notify@example.com>
#SMTP_SECURE=false

# --- Per-key limits ---
MAX_ADDRESSES_PER_KEY=10
MAX_CHANNELS_PER_KEY=10
MAX_PUSH_TOKENS_PER_KEY=10
ACTIVITY_RETENTION_DAYS=90

# --- Admin keys ---
# Comma-separated SHA-256 hashes of personal keys that get admin status:
# no address/channel/push-token limits and activity that is never pruned.
# Generate a hash with: bun run hash-key ck_<personal key>
#ADMIN_KEY_HASHES=
